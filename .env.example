# RAG Chatbot Configuration

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# LLM Configuration
# Supported models installed via Ollama (llama3, mistral, neural-chat, etc.)
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Data Configuration
DATA_DIR=data

# Vector Store Configuration
VECTOR_STORE_PATH=faiss_index
CHUNK_SIZE=500
CHUNK_OVERLAP=50
